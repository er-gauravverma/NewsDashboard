<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- AlarmManager exact alarms (Android 12+) -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <!-- Notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Boot receiver to reschedule alarms after reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Keep CPU awake during alarm work -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:name=".TradingWatchlistApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.TradingWatchlist">

        <!-- Main watchlist activity -->
        <activity
            android:name=".ui.watchlist.WatchlistActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Price alerts management activity -->
        <activity
            android:name=".ui.alerts.AlertsActivity"
            android:exported="false"
            android:parentActivityName=".ui.watchlist.WatchlistActivity"
            android:label="@string/title_alerts" />

        <!-- BroadcastReceiver: triggered by AlarmManager every 5 minutes -->
        <receiver
            android:name=".background.PriceUpdateReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.tradingwatchlist.ACTION_PRICE_UPDATE" />
            </intent-filter>
        </receiver>

        <!-- BroadcastReceiver: reschedule alarm after device reboot -->
        <receiver
            android:name=".background.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
